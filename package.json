{
  "name": "juegoglobo",
  "version": "1.0.0",
  "description": "UnGlobo: Risk It! - Juego de globos-pop",
  "main": "index.js",
  "scripts": {
    "fix:java": "node -e \"const fs=require('fs');const f='android/app/capacitor.build.gradle';if(fs.existsSync(f)){let c=fs.readFileSync(f,'utf8');c=c.replace(/JavaVersion.VERSION_21/g,'JavaVersion.VERSION_17');fs.writeFileSync(f,c);console.log('Corregido capacitor.build.gradle a Java 17');}\"",
    "build:android": "npx cap sync android && npm run fix:java && node scripts/generate-icons.js && cd android && ./gradlew assembleDebug && cd .. && node scripts/copy-apk.js",
    "generate:icons": "node scripts/generate-icons.js",
    "serve": "npx serve www -l 3000",
    "dev": "npx serve www -l 3000",
    "clean": "cd android && ./gradlew clean"
  },
  "keywords": ["game", "capacitor", "android", "globo"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "serve": "^14.2.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0"
  }
}